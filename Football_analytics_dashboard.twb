            </column>
            <column caption='Model Accuracy %' datatype='real' name='[Calculation_0685318605737986]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Calculation_0476398864924673] = &quot;Correct&quot; THEN 1 ELSE 0 END) / COUNT([Calculation_0476398864924673])' />
