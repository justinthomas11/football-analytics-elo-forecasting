  <worksheets>
    <worksheet name='Confidence Accuracy'>
      <repository-location derived-from='https://public.tableau.com/workbooks/Dashboard_17731587191590/ConfidenceAccuracy?rev=' id='127816036' path='/workbooks/Dashboard_17731587191590' revision='' />
      <table>
        <view>
          <datasources>
            <datasource caption='Football_Tableau' name='federated.09k2i2t0gydjew14mr34h1ga81oj' />
          </datasources>
          <datasource-dependencies datasource='federated.09k2i2t0gydjew14mr34h1ga81oj'>
            <column caption='ModelCorrect?' datatype='string' name='[Calculation_0476398864924673]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [PredictedLabel] = &#13;&#10;IF [FTHome] &gt; [FTAway] THEN &quot;Home&quot;&#13;&#10;ELSEIF [FTHome] &lt; [FTAway] THEN &quot;Away&quot;&#13;&#10;ELSE &quot;Draw&quot;&#13;&#10;END&#13;&#10;THEN &quot;Correct&quot; ELSE &quot;Wrong&quot; END' />
            </column>
            <column caption='Season' datatype='integer' name='[Calculation_0685318604623872]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='YEAR([MatchDate])' />
            </column>
            <column caption='Home Win Prob' datatype='real' name='[Calculation_0685318607769603]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[OddHome] / ([OddHome] + [OddAway] + [OddDraw])' />
            </column>
            <column caption='Confidence Bucket' datatype='string' name='[Calculation_0685318608019460]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0685318607769603] &gt;= 0.5 THEN &quot;High&quot;&#13;&#10;ELSEIF [Calculation_0685318607769603] &gt;= 0.35 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;Low&quot;&#13;&#10;END' />
            </column>
